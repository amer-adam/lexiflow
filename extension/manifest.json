{
  "manifest_version": 3,
  "name": "LexiFlow for YouTube",
  "version": "0.1.0",
  "description": "Send any YouTube video to LexiFlow and study it with graded Chinese subtitles, word lookup, and TTS right on top of the player.",
  "permissions": ["storage", "alarms", "activeTab"],
  "host_permissions": [
    "https://api-test.amerai.top/*",
    "https://test.amerai.top/*",
    "https://lexiflow.amerai.top/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "LexiFlow"
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/watch*"],
      "js": ["content/youtube-overlay.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://test.amerai.top/*", "https://lexiflow.amerai.top/*"],
      "js": ["content/auth-relay.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["content/overlay.css"],
      "matches": ["*://*.youtube.com/*"]
    }
  ]
}
