generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// SHARED ENUMS
// ==========================================
enum ListType {
  USER_CREATED
  SAVED
  SEEN
  OFFICIAL
}

enum QuestionType {
  MULTIPLE_CHOICE
  FILL_BLANK
  SHORT_ANSWER
  TRUE_FALSE
}

// ==========================================
// VOCABULARY DOMAIN
// ==========================================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())

  // Relations
  vocabularyLists VocabularyList[]
  flashcardDecks  FlashcardDeck[]
  quizzes         Quiz[]
  quizAttempts    QuizAttempt[]
}

/// The CENTRAL ENTITY. Never duplicated.
model VocabularyItem {
  id                String   @id @default(uuid())
  simplified        String   @unique
  traditional       String?
  pinyin            String
  meaning           String
  hskLevel          Int?
  frequencyRank     Int?
  embeddingVectorId String? // Reference to external vector DB or cache
  createdAt         DateTime @default(now())

  // Relations
  listItems     VocabularyListItem[]
  flashcards    Flashcard[]
  quizQuestions QuizQuestion[]

  // Cache Relations
  distractorCache DistractorCache?
  ttsAudioCache   TTSAudioCache?
  embeddingCache  EmbeddingCache?
}

model VocabularyList {
  id             String   @id @default(uuid())
  userId         String? // Nullable for SYSTEM/OFFICIAL lists
  name           String
  type           ListType
  sourceMetadata Json? // Stores external info (e.g., official source name)
  createdAt      DateTime @default(now())

  user          User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  items         VocabularyListItem[]
  flashcardDeck FlashcardDeck?

  @@unique([userId, name]) // A user cannot have two lists with the same name
}

model VocabularyListItem {
  id               String   @id @default(uuid())
  listId           String
  vocabularyId     String
  sourceVideoId    String? // The video where this was seen/saved
  familiarityScore Float    @default(0.0)
  seenCount        Int      @default(1)
  lastSeenAt       DateTime @default(now())
  addedAt          DateTime @default(now())

  contextSentence    String? // The raw sentence segment containing the target word
  contextTranslation String? // English translation matching that specific subtitle segment

  list       VocabularyList @relation(fields: [listId], references: [id], onDelete: Cascade)
  vocabulary VocabularyItem @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)

  @@unique([listId, vocabularyId])
}

// ==========================================
// LEARNING DOMAIN (SRS & QUIZ)
// ==========================================

model FlashcardDeck {
  id        String   @id @default(uuid())
  userId    String
  name      String
  listId    String   @unique // Linked 1:1 with a VocabularyList
  createdAt DateTime @default(now())

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  vocabularyList VocabularyList? @relation(fields: [listId], references: [id], onDelete: SetNull)
  flashcards     Flashcard[]
}

model Flashcard {
  id           String @id @default(uuid())
  deckId       String
  vocabularyId String

  // Customization JSON objects: e.g., {"character": true, "pinyin": false} or ["simplified", "pinyin"]
  frontConfig Json
  backConfig  Json

  // Modern FSRS Algorithm Memory State Tracking Parameters
  stability     Float @default(0.0) // S: Days required for retention to fall to 90%
  difficulty    Float @default(0.0) // D: Intrinsic cognitive complexity of the card (1.0 - 10.0)
  elapsedDays   Int   @default(0) // Days since last review
  scheduledDays Int   @default(0) // Calculated optimal interval until next iteration
  state         Int   @default(0) // FSRS state integer: 0=New, 1=Learning, 2=Review, 3=Relearning

  nextReviewDate DateTime @default(now())
  createdAt      DateTime @default(now())

  deck       FlashcardDeck     @relation(fields: [deckId], references: [id], onDelete: Cascade)
  vocabulary VocabularyItem    @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)
  reviews    FlashcardReview[]

  @@unique([deckId, vocabularyId])
  @@index([nextReviewDate])
}

model FlashcardReview {
  id           String @id @default(uuid())
  flashcardId  String
  qualityScore Int // FSRS Rating scales: 1=Again, 2=Hard, 3=Good, 4=Easy

  // Algorithmic snapshots for back-tracking or performance analytical computations
  lastStability  Float
  lastDifficulty Float
  scheduledDays  Int

  reviewedAt DateTime @default(now())

  flashcard Flashcard @relation(fields: [flashcardId], references: [id], onDelete: Cascade)
}

model Quiz {
  id        String   @id @default(uuid())
  userId    String
  title     String
  createdAt DateTime @default(now())

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  attempts  QuizAttempt[]
}

model QuizQuestion {
  id            String       @id @default(uuid())
  quizId        String
  vocabularyId  String
  type          QuestionType
  questionText  String // e.g., The context sentence with a blank
  correctAnswer String
  distractors   Json // Array of plausible wrong answers

  quiz       Quiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  vocabulary VocabularyItem @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)
  answers    QuizAnswer[]
}

model QuizAttempt {
  id          String    @id @default(uuid())
  quizId      String
  userId      String
  score       Float?
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  quiz    Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]
}

model QuizAnswer {
  id         String  @id @default(uuid())
  attemptId  String
  questionId String
  userAnswer String
  isCorrect  Boolean

  gradingScore Float? // Cosine similarity float value between 0.0 and 1.0 from SBERT
  feedback     String? // Textual flag indicator: e.g., "Exact", "Acceptable", "Partial Credit"
  answeredAt   DateTime @default(now())

  attempt  QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

// ==========================================
// AI METADATA DOMAIN (CACHES)
// ==========================================

model EmbeddingCache {
  id           String   @id @default(uuid())
  vocabularyId String   @unique
  vectorData   Json // Holds the numerical array if stored locally
  updatedAt    DateTime @updatedAt

  vocabulary VocabularyItem @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)
}

model DistractorCache {
  id           String   @id @default(uuid())
  vocabularyId String   @unique
  distractors  Json // Pre-generated semantic/phonetic distractors
  generatedAt  DateTime @default(now())

  vocabulary VocabularyItem @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)
}

model TTSAudioCache {
  id           String   @id @default(uuid())
  vocabularyId String   @unique
  audioUrl     String // Local path or S3 bucket URL
  generatedAt  DateTime @default(now())

  vocabulary VocabularyItem @relation(fields: [vocabularyId], references: [id], onDelete: Cascade)
}

model UserWatchProgress {
  id                   String   @id @default(uuid())
  userId               String // Auth0 user ID
  videoId              String // MongoDB video job ID
  currentTime          Float // Seconds into video
  duration             Float // Total video length in seconds
  lastSegmentIndexSeen Int      @default(-1) // Tracks which subtitle segment was last processed for vocab sync
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@unique([userId, videoId]) // Prevent duplicate progress records per user-video pair
  @@index([userId]) // Fast lookup by user
  @@index([updatedAt]) // Query recent progress
}
